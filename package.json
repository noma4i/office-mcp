{
  "name": "office-mcp",
  "version": "0.1.1",
  "description": "MCP server for controlling Microsoft Word and Excel via AppleScript on macOS",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "node scripts/build.js",
    "build:watch": "node scripts/build.js --watch",
    "dev": "yarn build && node dist/index.js",
    "start": "node dist/index.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules yarn jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules yarn jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules yarn jest --coverage --watchman=false",
    "test:applescript:strict": "APPLE_SCRIPT_STRICT_COMPILE=1 NODE_OPTIONS=--experimental-vm-modules yarn jest tests/applescript-syntax.test.js tests/excel-applescript-syntax.test.js tests/applescript-registry.test.js --watchman=false",
    "test:word-find:live": "WORD_LIVE_TESTS=1 NODE_OPTIONS=--experimental-vm-modules yarn jest tests/word-find-live.test.js --runInBand --watchman=false",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist/",
    "manifest.json",
    "icon.png"
  ],
  "author": {
    "name": "noma4i",
    "url": "https://github.com/noma4i"
  },
  "contributors": [
    {
      "name": "Anthropic",
      "url": "https://www.anthropic.com"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/noma4i/office-mcp.git"
  },
  "license": "MIT",
  "homepage": "https://github.com/noma4i/office-mcp",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.21.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0"
  },
  "packageManager": "yarn@3.6.1+sha512.de524adec81a6c3d7a26d936d439d2832e351cdfc5728f9d91f3fc85dd20b04391c038e9b4ecab11cae2b0dd9f0d55fd355af766bc5c1a7f8d25d96bb2a0b2ca"
}
